{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhr-solar.github.io/photon/photon-view.schema.json",
  "title": "Photon Custom View",
  "type": "object",
  "required": ["schemaVersion", "id", "name"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "layout": {
      "type": "object",
      "required": ["columns", "rowHeight", "gap"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1, "maximum": 48 },
        "rowHeight": { "type": "number", "minimum": 48, "maximum": 1200 },
        "gap": { "type": "number", "minimum": 0, "maximum": 64 }
      },
      "additionalProperties": true
    },
    "widgets": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/widget" }
    },
    "activePanel": { "type": "integer", "minimum": 0 },
    "panels": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/panel" }
    }
  },
  "$defs": {
    "panel": {
      "type": "object",
      "required": ["id", "name", "layout", "widgets"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "layout": {
          "type": "object",
          "required": ["columns", "rowHeight", "gap"],
          "properties": {
            "columns": { "type": "integer", "minimum": 1, "maximum": 48 },
            "rowHeight": { "type": "number", "minimum": 48, "maximum": 1200 },
            "gap": { "type": "number", "minimum": 0, "maximum": 64 }
          },
          "additionalProperties": true
        },
        "widgets": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/widget" }
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "required": ["messageId"],
      "properties": {
        "messageId": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 8191 },
            { "type": "string", "pattern": "^(0[xX][0-9a-fA-F]+|[0-9]+)$" }
          ]
        },
        "messageName": { "type": "string" },
        "signalName": { "type": "string" },
        "signalIndex": { "type": "integer", "minimum": 0, "maximum": 63 },
        "label": { "type": "string" },
        "scale": { "type": "number" },
        "offset": { "type": "number" }
      },
      "additionalProperties": true
    },
    "rect": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1, "maximum": 48 }
      },
      "additionalProperties": false
    },
    "plot": {
      "type": "object",
      "required": ["type", "sources"],
      "properties": {
        "type": {
          "enum": [
            "line", "filled-line", "shaded", "scatter", "stairstep", "bar",
            "bar-groups", "bar-stacks", "error-bars", "stem", "pie", "heatmap",
            "histogram", "histogram-2d", "digital", "line-3d", "scatter-3d",
            "surface-3d", "list", "tire-slip"
          ]
        },
        "title": { "type": "string" },
        "useSource1TimeAsX": { "type": "boolean" },
        "sources": { "type": "array", "minItems": 0, "maxItems": 128, "items": { "$ref": "#/$defs/source" } },
        "options": { "type": "object" }
      },
      "additionalProperties": true
    },
    "cellGrid": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cols": { "type": "integer", "minimum": 1, "maximum": 32 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 32 },
        "mode": { "enum": ["voltage", "temperature"] },
        "voltageMessageId": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 8191 },
            { "type": "string", "pattern": "^(0[xX][0-9a-fA-F]+|[0-9]+)$" }
          ]
        },
        "temperatureMessageId": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 8191 },
            { "type": "string", "pattern": "^(0[xX][0-9a-fA-F]+|[0-9]+)$" }
          ]
        },
        "statusMessageId": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 8191 },
            { "type": "string", "pattern": "^(0[xX][0-9a-fA-F]+|[0-9]+)$" }
          ]
        }
      },
      "additionalProperties": true
    },
    "watchdog": {
      "type": "object",
      "required": ["source", "threshold"],
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "unit": { "type": "string" },
        "comparison": { "enum": ["below", "above"] },
        "threshold": { "type": "number" },
        "hideWhenOk": { "type": "boolean" },
        "source": { "$ref": "#/$defs/source" }
      },
      "additionalProperties": true
    },
    "canMonitor": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "filter": { "type": "string" },
        "recordPath": { "type": "string" },
        "sort": { "type": "integer", "minimum": 0, "maximum": 3 }
      },
      "additionalProperties": true
    },
    "widget": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "kind", "rect", "plot"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "plot" },
            "rect": { "$ref": "#/$defs/rect" },
            "plot": { "$ref": "#/$defs/plot" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["id", "kind", "rect", "cellGrid"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "cell-grid" },
            "rect": { "$ref": "#/$defs/rect" },
            "cellGrid": { "$ref": "#/$defs/cellGrid" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["id", "kind", "rect", "watchdog"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "watchdog" },
            "rect": { "$ref": "#/$defs/rect" },
            "watchdog": { "$ref": "#/$defs/watchdog" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["id", "kind", "rect", "canMonitor"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "can-monitor" },
            "rect": { "$ref": "#/$defs/rect" },
            "canMonitor": { "$ref": "#/$defs/canMonitor" }
          },
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": true
}
