{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhr-solar.github.io/photon/photon-view.schema.json",
  "title": "Photon Custom View",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "layout", "widgets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "layout": {
      "type": "object",
      "required": ["columns", "rowHeight", "gap"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1, "maximum": 48 },
        "rowHeight": { "type": "number", "minimum": 48, "maximum": 1200 },
        "gap": { "type": "number", "minimum": 0, "maximum": 64 }
      },
      "additionalProperties": true
    },
    "widgets": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/widget" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["messageId"],
      "properties": {
        "messageId": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 8191 },
            { "type": "string", "pattern": "^(0[xX][0-9a-fA-F]+|[0-9]+)$" }
          ]
        },
        "messageName": { "type": "string" },
        "signalName": { "type": "string" },
        "signalIndex": { "type": "integer", "minimum": 0, "maximum": 31 },
        "label": { "type": "string" }
      },
      "additionalProperties": true
    },
    "rect": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1, "maximum": 24 }
      },
      "additionalProperties": false
    },
    "plot": {
      "type": "object",
      "required": ["type", "sources"],
      "properties": {
        "type": {
          "enum": [
            "line", "filled-line", "shaded", "scatter", "stairstep", "bar",
            "bar-groups", "bar-stacks", "error-bars", "stem", "pie", "heatmap",
            "histogram", "histogram-2d", "digital", "line-3d", "scatter-3d",
            "surface-3d", "list"
          ]
        },
        "title": { "type": "string" },
        "useSource1TimeAsX": { "type": "boolean" },
        "sources": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "$ref": "#/$defs/source" } },
        "options": { "type": "object" }
      },
      "additionalProperties": true
    },
    "widget": {
      "type": "object",
      "required": ["id", "kind", "rect", "plot"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "plot" },
        "rect": { "$ref": "#/$defs/rect" },
        "plot": { "$ref": "#/$defs/plot" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
