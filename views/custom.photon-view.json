    {
      "id": "live-can",
      "layout": {
        "columns": 48,
        "gap": 8.0,
        "rowHeight": 48.0
      },
      "name": "Live CAN",
      "widgets": [
        {
          "canMonitor": {
            "filter": "",
            "recordPath": "views/highnoon-can.log",
            "sort": 0,
            "title": "Live CAN Monitor"
          },
          "id": "can-monitor",
          "kind": "can-monitor",
          "rect": {
            "h": 12,
            "w": 48,
            "x": 0,
            "y": 0
          }
        }
      ]
    },
    {
