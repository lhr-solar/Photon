            "sources": [
              {
                "messageId": 4560,
                "messageName": "IMU_Accel_FL",
                "signalName": "Accel_Z",
                "label": "Lateral acceleration - left positive (g)",
                "scale": -1.0,
                "offset": 0.0403
              },
              {
                "messageId": 4560,
                "messageName": "IMU_Accel_FL",
                "signalName": "Accel_Y",
                "label": "Longitudinal acceleration - forward positive (g)",
                "offset": -0.0033
              }
            ],
            "timeWindowSeconds": 60.0,
            "title": "FL GG - lateral vs longitudinal",
            "type": "scatter",
            "useSource1TimeAsX": false
